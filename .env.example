# API
API_SECRET_KEY=your_api_secret_key_here

# DuckDB — local file (default). Uncomment MOTHERDUCK_TOKEN to use cloud instead.
DUCKDB_PATH=data/db/jonas.duckdb
# MOTHERDUCK_TOKEN=your_motherduck_token_here

# Parquet storage root (local filesystem; swap for gs:// or s3:// path in production)
PARQUET_ROOT=data/parquet

# LLM provider selection (openai | google | ollama)
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2

# OpenAI (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini via OpenAI-compatible API (required when LLM_PROVIDER=google)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Ollama via OpenAI-compatible API (required when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
# Ollama reasoning/thinking is disabled by the API service.

# Dashboard (set at Vite build time or injected at runtime)
VITE_API_URL=http://localhost:8000
